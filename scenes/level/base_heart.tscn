; Base Heart Core scene.
; Place at the center of the map. The HealthComponent controls its vitality pool.
; The script base_heart.gd handles group registration and the defeat RPC.
[gd_scene load_steps=6 format=3 uid="uid://base_heart_001"]

[ext_resource type="Script" path="res://scripts/base_heart.gd" id="1_bheart"]
[ext_resource type="Script" path="res://scripts/health_component.gd" id="2_health"]

[sub_resource type="BoxShape3D" id="BoxShape3D_heart"]
size = Vector3(1.2, 1.2, 1.2)

[sub_resource type="BoxMesh" id="BoxMesh_heart"]
size = Vector3(1.0, 1.0, 1.0)

[sub_resource type="StandardMaterial3D" id="StandardMaterial3D_heart"]
