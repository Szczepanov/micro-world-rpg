emission_enabled = true
emission = Color(0.05, 0.80, 0.85, 1)
emission_energy_multiplier = 2.5
metallic = 0.3
roughness = 0.2

[node name="BaseHeart" type="StaticBody3D"]
collision_layer = 4
collision_mask = 0
