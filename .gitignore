.godot/
*.translation
*.gdc
export_presets.cfg

# ---- 2. Application Runtime Databases & Journals ----
*.db
*.db-wal
*.db-shm
*.log

# ---- 3. Automated Compilations & Deployment Contexts ----
build/
server_build/
*.zip
*.tpz

# ---- 4. Third-Party / Operating System Garbage Collections ----
.DS_Store
Thumbs.db
.vscode/
.idea/
*.tmp
*.TMP
# Server build binaries
server.pck
server.x86_64

# Client build binaries
client.pck
client.x86_64
