# =============================================================================
# Pocket Realms — Docker Build Exclusions Configuration
# =============================================================================

# ---- 1. Core Git & Local Cache Cavities ----
.git
.godot/
scratch/
*.log

# ---- 2. Raw Asset Folders ----
assets/
scenes/
scripts/

# ---- 3. Testing Frameworks ----
test/

# ---- 4. Third-Party Extensions Defaults ----
addons/

# ---- 5. Surgical Whitelist for Database Drivers ----
!addons/godot-sqlite/
!addons/godot-sqlite/godot-sqlite.gd
!addons/godot-sqlite/plugin.cfg
!addons/godot-sqlite/gdsqlite.gdextension
!addons/godot-sqlite/bin/
!addons/godot-sqlite/bin/*linux*.so
